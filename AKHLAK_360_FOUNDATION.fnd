# AKHLAK_360_FOUNDATION.fnd
# Foundation & Technical Context — Sistem Penilaian 360° AKHLAK
# Gunakan file ini sebagai referensi teknis saat membangun sistem

---

## SKEMA DATABASE (Class Diagram → SQL)

```sql
-- ============================================================
-- TABLE: roles
-- ============================================================
CREATE TABLE roles (
    id_role       INT PRIMARY KEY AUTO_INCREMENT,
    role_name     VARCHAR(50) NOT NULL,  -- 'hr', 'karyawan', 'evaluator', 'management'
    description   VARCHAR(255)
);

-- ============================================================
-- TABLE: employees
-- ============================================================
CREATE TABLE employees (
    user_id       INT PRIMARY KEY AUTO_INCREMENT,
    id_supervisor INT NULL,              -- FK ke employees.user_id (atasan langsung)
    nama          VARCHAR(100) NOT NULL,
    email         VARCHAR(100) UNIQUE NOT NULL,
    nip           VARCHAR(20) UNIQUE NOT NULL,
    position      VARCHAR(100),
    division      VARCHAR(100),
    FOREIGN KEY (id_supervisor) REFERENCES employees(user_id)
);

-- ============================================================
-- TABLE: user_accounts
-- ============================================================
CREATE TABLE user_accounts (
    id_account    INT PRIMARY KEY AUTO_INCREMENT,
    id_employee   INT NOT NULL,
    id_role       INT NOT NULL,
    username      VARCHAR(50) UNIQUE NOT NULL,
    password      VARCHAR(255) NOT NULL,  -- bcrypt hash
    status        VARCHAR(20) DEFAULT 'active',  -- 'active', 'inactive'
    FOREIGN KEY (id_employee) REFERENCES employees(user_id),
    FOREIGN KEY (id_role) REFERENCES roles(id_role)
);

-- ============================================================
-- TABLE: assessment_periods
-- ============================================================
CREATE TABLE assessment_periods (
    id_period     INT PRIMARY KEY AUTO_INCREMENT,
    period_name   VARCHAR(100) NOT NULL,  -- e.g. "Semester 1 2026"
    start_date    DATE NOT NULL,
    end_date      DATE NOT NULL,
    status        VARCHAR(20) DEFAULT 'draft'  -- 'draft', 'active', 'closed'
);

-- ============================================================
-- TABLE: indikators
-- ============================================================
CREATE TABLE indikators (
    id_indikator  INT PRIMARY KEY AUTO_INCREMENT,
    core_value    INT NOT NULL,           -- 1=Amanah, 2=Kompeten, 3=Harmonis,
                                          -- 4=Loyal, 5=Adaptif, 6=Kolaboratif
    indikator_name VARCHAR(255) NOT NULL,
    nilai_min     INT DEFAULT 1,
    nilai_max     INT DEFAULT 5
);

-- ============================================================
-- TABLE: penilaians (header penilaian per evaluator per periode)
-- ============================================================
CREATE TABLE penilaians (
    id_penilaian  INT PRIMARY KEY AUTO_INCREMENT,
    id_period     INT NOT NULL,
    id_evaluator  INT NOT NULL,           -- FK employees.user_id (yang menilai)
    id_karyawan   INT NOT NULL,           -- FK employees.user_id (yang dinilai)
    jenis_penilaian VARCHAR(20) NOT NULL, -- 'atasan', 'rekan', 'bawahan', 'self'
    status        VARCHAR(20) DEFAULT 'pending', -- 'pending', 'submitted'
    submitted_at  DATETIME NULL,
    FOREIGN KEY (id_period) REFERENCES assessment_periods(id_period),
    FOREIGN KEY (id_evaluator) REFERENCES employees(user_id),
    FOREIGN KEY (id_karyawan) REFERENCES employees(user_id)
);

-- ============================================================
-- TABLE: detail_penilaians (skor per indikator)
-- ============================================================
CREATE TABLE detail_penilaians (
    id_detail     INT PRIMARY KEY AUTO_INCREMENT,
    penilaian_id  INT NOT NULL,
    id_indikator  INT NOT NULL,
    score         INT NOT NULL,           -- nilai antara nilai_min dan nilai_max
    feedback      TEXT NULL,
    FOREIGN KEY (penilaian_id) REFERENCES penilaians(id_penilaian),
    FOREIGN KEY (id_indikator) REFERENCES indikators(id_indikator)
);

-- ============================================================
-- TABLE: hasil_akhirs (hasil final setelah dihitung sistem)
-- ============================================================
CREATE TABLE hasil_akhirs (
    id_result     INT PRIMARY KEY AUTO_INCREMENT,
    id_employee   INT NOT NULL,
    id_period     INT NOT NULL,
    score_atasan  DECIMAL(5,2) NULL,
    score_bawahan DECIMAL(5,2) NULL,
    score_rekan   DECIMAL(5,2) NULL,
    score_self    DECIMAL(5,2) NULL,
    total_score   DECIMAL(5,2) NULL,      -- weighted final score
    category      VARCHAR(50) NULL,       -- 'Sangat Baik', 'Baik', 'Cukup', 'Kurang'
    calculated_at DATETIME NULL,
    FOREIGN KEY (id_employee) REFERENCES employees(user_id),
    FOREIGN KEY (id_period) REFERENCES assessment_periods(id_period)
);

-- ============================================================
-- TABLE: hasil_reports
-- ============================================================
CREATE TABLE hasil_reports (
    id_report     INT PRIMARY KEY AUTO_INCREMENT,
    id_result     INT NOT NULL,
    report_type   VARCHAR(50),            -- 'pdf', 'excel'
    generate_date DATE,
    generated_by  INT,                    -- FK employees.user_id
    FOREIGN KEY (id_result) REFERENCES hasil_akhirs(id_result)
);
```

